# Enable caching of up to 1000 output entries
cache-size=1000

# Don't show owner on index page
enable-index-owner=0

# Allow http transport git clone
enable-http-clone=1

# Show extra links for each repository on the index page
enable-index-links=1

# Enable blame page and create links to it from tree page
enable-blame=1

# Enable ASCII art commit history graph on the log pages
enable-commit-graph=1

# Enable git config to set repo specific settings
enable-git-config=1

# Enable following files on the log pages
enable-follow-links=1

# Show number of affected files per commit on the log pages
enable-log-filecount=1

# Show number of added/removed lines per commit on the log pages
enable-log-linecount=1

# Sort branches by date
branch-sort=age

# Enable statistics per week, month and quarter
max-stats=year

# Set the title and heading of the repository index page
root-title=cgit

# Set a subheading for the repository index page
root-desc=Lightweight git frontend (read-only)

# Include some more info about example.com on the index page
root-readme=/usr/share/webapps/cgit/about.md

# Allow download of tar.gz, tar.bz2 and zip-files
snapshots=tar.gz zip

## List of common mimetypes
mimetype-file=/etc/mime.types

# Syntax highlighting filter
source-filter=/usr/lib/cgit/filters/syntax-highlighting.sh

# About page formatting filter
about-filter=/usr/lib/cgit/filters/about-formatting.sh

# Root for cgit urls
virtual-root=/

# Strip .git suffix from repo names and urls
remove-suffix=1

# Default section names
section-from-path=1

# Directory to scan for repositories
scan-path=/srv/git

